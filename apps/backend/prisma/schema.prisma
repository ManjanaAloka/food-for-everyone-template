generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SYSTEM_ADMIN
  MANAGER
  CUSTOMER
  PROVIDER
  DONATION_CENTER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  EXPIRED
  HIDDEN
}

enum OrderType {
  PERSONAL
  DONATION
}

enum FulfillmentMode {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  CREATED
  RESERVED
  AWAITING_PAYMENT
  PAID
  PENDING
  READY_FOR_PICKUP
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY

  DELIVERED
  CANCELED
  EXPIRED
  REFUNDED
}


enum PaymentStatus {
  INITIATED
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  ONLINE
  COD
}

enum DonationRequestStatus {
  OPEN
  FULFILLED
  CLOSED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  role         Role
  status       UserStatus @default(PENDING)
  name         String
  totpSecret   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permissions  Json? // For admin tab access control
  forcePasswordChange Boolean @default(false)

  providerProfile       ServiceProvider?
  donationCenterProfile DonationCenter?
  reviews               Review[]
  orders                Order[] @relation("UserOrders")
  notifications         Notification[]
  refreshTokens         RefreshToken[]
  donations             Donation[]
  customerProfile       CustomerProfile?
  savedPaymentMethods   SavedPaymentMethod[]
  siteReviews           SiteReview[]
}


model ServiceProvider {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id])
  businessName  String
  brNo          String?
  tin           String?
  address       String?
  city          String?
  lat           Float?
  lng           Float?
  deliveryOptions Json?
  verifiedAt    DateTime?
  ratingAvg     Float     @default(0)
  ratingCount   Int       @default(0)
  
  openHours     String?
  businessType  String?   // Bakery, Supermarket, Cafe
  contactPerson String?
  logo          String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listings      Listing[]
  orders        Order[]   @relation("ProviderOrders")
}

model DonationCenter {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id])
  name           String
  registrationNo String?
  address        String?
  lat            Float?
  lng            Float?
  needsProfile   Json?
  description    String?   @db.Text
  verifiedAt     DateTime?
  
  centerType     String?   // Elderly Home, Childcare, NGO
  contactPerson  String?
  phone          String?
  beneficiariesCount Int?
  
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  donationOrders Order[]  @relation("DonationCenterOrders")
  requests       DonationRequest[]
  activities     DonationCenterActivity[]
}

model DonationCenterActivity {
  id           String   @id @default(cuid())
  centerId     String
  center       DonationCenter @relation(fields: [centerId], references: [userId])
  requestId    String?
  request      DonationRequest? @relation(fields: [requestId], references: [id])
  title        String
  content      String   @db.Text
  images       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerProfile {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id])
  idNumber      String?
  address       String?
  city          String?
  lat           Float?
  lng           Float?
  verificationDoc Json? 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cardType  String?  
  last4     String?
  expiry    String?
  token     String?  
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Listing {
  id            String         @id @default(cuid())
  providerId    String
  provider      ServiceProvider @relation(fields: [providerId], references: [userId])
  title         String
  description   String?
  category      String
  ingredients   String?
  unitPrice     Decimal        @db.Decimal(10,2)
  discountPrice Decimal        @db.Decimal(10,2)
  qtyAvailable  Int
  weightGrams   Int?
  expiresAt     DateTime
  status        ListingStatus  @default(ACTIVE)
  images        Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  orderItems        OrderItem[]
  donationRequests  DonationRequest[]
  @@index([expiresAt])
  @@index([providerId])
}

model DonationRequest {
  id           String   @id @default(cuid())
  centerId     String
  center       DonationCenter @relation(fields: [centerId], references: [userId])
  listingId    String?
  listing      Listing?  @relation(fields: [listingId], references: [id])
  title        String
  description  String?
  targetQty    Int       @default(0)
  fulfilledQty Int       @default(0)
  targetAmount Decimal   @db.Decimal(10,2) @default(0)
  raisedAmount Decimal   @db.Decimal(10,2) @default(0)
  donorCount   Int       @default(0)
  closesAt     DateTime?
  status       DonationRequestStatus @default(OPEN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders       Order[]
  donations    Donation[]
  activities   DonationCenterActivity[]
}

model Order {
  id                 String           @id @default(cuid())
  buyerId            String
  buyer              User             @relation("UserOrders", fields: [buyerId], references: [id])
  providerId         String
  provider           ServiceProvider  @relation("ProviderOrders", fields: [providerId], references: [userId])
  type               OrderType
  fulfillmentMode    FulfillmentMode
  paymentMethod      PaymentMethod
  donationCenterId   String?
  donationCenter     DonationCenter?  @relation("DonationCenterOrders", fields: [donationCenterId], references: [userId])
  donationRequestId  String?
  donationRequest    DonationRequest? @relation(fields: [donationRequestId], references: [id])
  status             OrderStatus      @default(CREATED)
  orderNumber        Int              @unique @default(autoincrement())
  scheduledTime      DateTime?

  addressLine        String?
  city               String?
  lat                Float?
  lng                Float?
  deliveryFee        Decimal?         @db.Decimal(10,2)
  subtotal           Decimal          @db.Decimal(10,2)
  total              Decimal          @db.Decimal(10,2)
  reservedUntil      DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  items              OrderItem[]
  payment            Payment?
  review             Review?
  @@index([status])
  @@index([providerId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  providerId  String
  qty         Int
  unitPrice   Decimal  @db.Decimal(10,2)
  snapshotExpiresAt DateTime
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  provider    String
  method      String?
  amount      Decimal       @db.Decimal(10,2)
  currency    String        @default("LKR")
  status      PaymentStatus @default(INITIATED)
  txnRef      String?       @unique
  gatewayPayload Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Review {
  id          String       @id @default(cuid())
  orderId     String       @unique
  order       Order        @relation(fields: [orderId], references: [id])
  reviewerId  String
  reviewer    User         @relation(fields: [reviewerId], references: [id])
  providerId  String
  rating      Int
  comment     String?
  providerResponse String?
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  channel   String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tokenHash  String
  revoked    Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
}

model Donation {
  id                String        @id @default(cuid())
  customerId        String
  customer          User          @relation(fields: [customerId], references: [id])
  donationRequestId String
  donationRequest   DonationRequest @relation(fields: [donationRequestId], references: [id])
  amount            Decimal       @db.Decimal(10,2)
  stripeSessionId   String?
  stripePaymentId   String?
  status            PaymentStatus @default(INITIATED)
  createdAt         DateTime      @default(now())

  @@index([donationRequestId])
  @@index([customerId])
}

model SiteReview {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  rating      Int
  comment     String?
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}
